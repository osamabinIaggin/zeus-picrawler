# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).

# Optional: OpenAI key, used ONLY as an online fallback when the Pi has internet.
# Zeus runs fully offline without this. Leave blank to stay 100% local.
OPENAI_API_KEY=

# Optional overrides (defaults shown are what zeus.py uses)
# OLLAMA_URL=http://localhost:11434/api/generate
# TEXT_MODEL=qwen2.5:1.5b
# VISION_MODEL=moondream:1.8b
# OPENAI_MODEL=gpt-4o-mini
